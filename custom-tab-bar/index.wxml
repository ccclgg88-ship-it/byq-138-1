<view class="tab-bar">
  <view
    wx:for="{{list}}"
    wx:key="pagePath"
    class="tab-item {{selected === index ? 'active' : ''}}"
    data-index="{{index}}"
    bindtap="switchTab"
  >
    <!-- CSS图标 -->
    <view class="tab-icon icon-{{item.icon}} {{selected === index ? 'active' : ''}}">
      <view class="icon-inner"></view>
    </view>
    <text class="tab-text">{{item.text}}</text>
    <view wx:if="{{selected === index}}" class="tab-indicator"></view>
  </view>
</view>
