.tip-card {
  background: #FFF0F3;
  border-radius: 24rpx;
  padding: 28rpx 28rpx 20rpx;
  position: relative;
  overflow: hidden;
}

/* 装饰性背景圆 */
.tip-card::before {
  content: '';
  position: absolute;
  top: -30rpx;
  right: -30rpx;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255, 107, 138, 0.06);
  pointer-events: none;
}

.tip-body {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.tip-icon {
  flex-shrink: 0;
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  background: rgba(255, 255, 255, 0.7);
  border-radius: 18rpx;
  box-shadow: 0 2rpx 8rpx rgba(255, 107, 138, 0.08);
}

.tip-text {
  flex: 1;
  font-size: 27rpx;
  color: #4A4A5A;
  line-height: 1.7;
  padding-top: 8rpx;
}

.tip-footer {
  display: flex;
  justify-content: flex-end;
  border-top: 1rpx solid rgba(255, 107, 138, 0.10);
  padding-top: 16rpx;
}

.refresh-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.6);
  transition: background 0.2s;
}

.refresh-btn:active {
  background: rgba(255, 255, 255, 0.9);
}

.refresh-icon {
  font-size: 28rpx;
  color: #FF6B8A;
  font-weight: 600;
}

.refresh-text {
  font-size: 24rpx;
  color: #FF6B8A;
  font-weight: 500;
}
