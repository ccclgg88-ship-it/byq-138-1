/**
 * app.wxss - 全局样式
 * 粉色系现代UI，简洁大气
 */

page {
  --color-primary: #FF6B8A;
  --color-primary-light: #FF8FA3;
  --color-primary-bg: #FFF5F7;
  --color-primary-pale: #FFE4EA;
  --color-secondary: #9B6BFF;
  --color-ovulation: #9B6BFF;
  --color-fertile: #E8DEFF;
  --color-safe: #4ECDC4;
  --color-safe-bg: #E8FAF8;
  --color-bg: #FFF5F7;
  --color-card: #FFFFFF;
  --color-text: #333333;
  --color-text-secondary: #666666;
  --color-text-light: #999999;
  --color-border: #F0F0F0;
  --color-shadow: rgba(255, 107, 138, 0.1);
  --radius-sm: 12rpx;
  --radius-md: 20rpx;
  --radius-lg: 28rpx;
  --radius-xl: 36rpx;

  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI',
    'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei',
    sans-serif;
  font-size: 28rpx;
  color: var(--color-text);
  background-color: var(--color-bg);
  line-height: 1.6;
}

/* 通用卡片 */
.card {
  background: var(--color-card);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  margin: 0 24rpx 24rpx;
  box-shadow: 0 4rpx 24rpx var(--color-shadow);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 20rpx;
}

/* 通用按钮 */
.btn-primary {
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));
  color: #FFFFFF;
  border: none;
  border-radius: var(--radius-xl);
  padding: 20rpx 48rpx;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 138, 0.3);
  transition: all 0.3s;
}

.btn-primary::after {
  border: none;
}

.btn-secondary {
  background: var(--color-primary-pale);
  color: var(--color-primary);
  border: none;
  border-radius: var(--radius-xl);
  padding: 16rpx 36rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.btn-secondary::after {
  border: none;
}

/* 标签 */
.tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.tag-pink {
  background: var(--color-primary-pale);
  color: var(--color-primary);
}

.tag-purple {
  background: var(--color-fertile);
  color: var(--color-ovulation);
}

.tag-green {
  background: var(--color-safe-bg);
  color: var(--color-safe);
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: var(--color-border);
  margin: 24rpx 0;
}

/* 页面容器 */
.page-container {
  padding-bottom: calc(130rpx + env(safe-area-inset-bottom));
  min-height: 100vh;
  box-sizing: border-box;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  color: var(--color-text-light);
}

.empty-state .empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-state .empty-text {
  font-size: 28rpx;
  text-align: center;
}

/* 渐变文字 */
.gradient-text {
  background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));
  -webkit-background-clip: text;
  color: transparent;
}

/* 加载动画 */
.loading-dot {
  display: inline-block;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--color-primary);
  animation: dotPulse 1.2s infinite;
}

@keyframes dotPulse {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.5; }
  40% { transform: scale(1); opacity: 1; }
}
