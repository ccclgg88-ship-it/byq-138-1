.page {
  min-height: 100vh;
  background-color: #FFF5F7;
  box-sizing: border-box;
}

/* ========== 顶部用户卡片 ========== */
.profile-card {
  background: linear-gradient(135deg, #FF9AB2 0%, #FF6B8A 100%);
  margin: 24rpx;
  padding: 48rpx 40rpx 40rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  position: relative;
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 138, 0.25);
}

.profile-card__avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
  flex-shrink: 0;
  box-shadow: 0 4rpx 16rpx rgba(255, 255, 255, 0.2);
}

.profile-card__info {
  flex: 1;
  margin-left: 28rpx;
  display: flex;
  flex-direction: column;
}

.profile-card__title {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1.4;
}

.profile-card__token {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 6rpx;
  line-height: 1.4;
}

.profile-card__stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 20rpx;
  padding: 16rpx 28rpx;
  flex-shrink: 0;
}

.profile-card__stat-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1.2;
}

.profile-card__stat-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 4rpx;
}

/* ========== 通用区块 ========== */
.section {
  padding: 0 24rpx;
  margin-top: 24rpx;
}

.section__title {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 16rpx;
  padding-left: 8rpx;
  font-weight: 500;
}

/* ========== 白色卡片 ========== */
.card {
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 24rpx rgba(255, 107, 138, 0.08);
  padding: 0;
}

/* ========== 单元格 ========== */
.cell {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  transition: background 0.2s;
}

.cell:active {
  background: #FFF5F7;
}

.cell__label {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.cell__value {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #666;
}

.cell__arrow {
  font-size: 32rpx;
  color: #ddd;
  margin-left: 12rpx;
}

.cell__divider {
  height: 1rpx;
  background: #F5F5F5;
  margin: 0 32rpx;
}

.cell__tag {
  font-size: 22rpx;
  color: #FF6B8A;
  background: #FFE4EA;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  margin-right: 8rpx;
  font-weight: 500;
}

/* ========== 危险操作 ========== */
.cell--danger:active {
  background: #FFF0F0;
}

.cell__label--danger {
  color: #E74C3C;
  font-weight: 500;
}

.cell__arrow--danger {
  color: #E74C3C;
}

/* ========== 底部信息 ========== */
.footer {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 64rpx;
  padding-bottom: 20rpx;
}

.footer__version {
  font-size: 24rpx;
  color: #ccc;
}

.footer__slogan {
  font-size: 22rpx;
  color: #ddd;
  margin-top: 8rpx;
}

/* ========== 底部安全区占位 ========== */
.bottom-spacer {
  height: calc(env(safe-area-inset-bottom) + 120rpx);
}
