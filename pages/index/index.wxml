<view class="page">
  <!-- 日历组件 -->
  <view class="section calendar-section">
    <calendar
      periods="{{periods}}"
      settings="{{settings}}"
      selected-date="{{selectedDate}}"
      bind:dateSelect="onDateSelect"
    />
  </view>

  <!-- 经期状态卡片 -->
  <view class="section status-section">
    <period-status status="{{currentStatus}}" />
  </view>

  <!-- 温馨提示卡片 -->
  <view class="section tip-section">
    <tip-card tip="{{currentTip}}" bind:refresh="onTipRefresh" />
  </view>

  <!-- 健康知识中心入口 -->
  <view class="section health-entry-section" bindtap="onGoHealth">
    <view class="health-entry-card">
      <view class="health-entry-left">
        <view class="health-entry-icon">📚</view>
        <view class="health-entry-content">
          <view class="health-entry-title">健康知识中心</view>
          <view class="health-entry-sub">{{phaseText}} · 24篇精选好文</view>
        </view>
      </view>
      <view class="health-entry-arrow">›</view>
    </view>
  </view>

  <!-- 本周症状速览 -->
  <view class="section symptom-preview-section" bindtap="onGoHealthRecord">
    <view class="symptom-preview-card">
      <view class="sp-header">
        <view class="sp-title-wrap">
          <text class="sp-icon">📊</text>
          <text class="sp-title">本周症状速览</text>
        </view>
        <text class="sp-link">健康档案 ›</text>
      </view>
      <view class="sp-stats">
        <view class="sp-stat-item">
          <view class="sp-stat-value">{{weeklyOverview.recordCount}}/7</view>
          <view class="sp-stat-label">天记录</view>
        </view>
        <view class="sp-stat-divider"></view>
        <view class="sp-stat-item">
          <view class="sp-stat-value sp-mood-icon">{{weeklyOverview.dominantMoodIcon || '—'}}</view>
          <view class="sp-stat-label">主导心情</view>
        </view>
        <view class="sp-stat-divider"></view>
        <view class="sp-stat-item">
          <view class="sp-stat-value">{{weeklyOverview.topSymptoms.length}}</view>
          <view class="sp-stat-label">种症状</view>
        </view>
      </view>
      <view class="sp-symptoms" wx:if="{{weeklyOverview.topSymptoms.length}}">
        <view class="sp-symptom-chip" wx:for="{{weeklyOverview.topSymptoms}}" wx:key="key">
          <text class="sp-chip-icon">{{item.icon}}</text>
          <text class="sp-chip-label">{{item.label}}</text>
        </view>
      </view>
      <view class="sp-empty" wx:else>
        <text class="sp-empty-text">还没有症状记录，开始记录发现身体规律</text>
      </view>
    </view>
  </view>

  <!-- 浮动操作按钮 -->
  <view
    class="fab {{isInPeriod ? 'fab--end' : 'fab--start'}}"
    bindtap="togglePeriod"
  >
    <text class="fab__text">{{isInPeriod ? '结束经期' : '记录经期'}}</text>
  </view>

  <!-- 底部占位，防止 FAB 遮挡内容 -->
  <view class="bottom-spacer"></view>
</view>
