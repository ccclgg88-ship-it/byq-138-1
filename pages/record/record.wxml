<!--pages/record/record.wxml - 日期记录页-->
<view class="page-container record-page">

  <!-- 日期信息头 -->
  <view class="date-header">
    <view class="date-text">{{displayDate}}</view>
    <view class="phase-tag {{phaseClass}}" wx:if="{{phaseLabel}}">{{phaseLabel}}</view>
  </view>

  <!-- 经期操作区 -->
  <view class="card period-card">
    <view class="card-title">经期状态</view>

    <!-- 已记录经期 -->
    <block wx:if="{{isInPeriod}}">
      <view class="period-info">
        <view class="period-day-badge">经期第{{periodDayNum}}天</view>
      </view>
      <view class="period-actions">
        <button class="btn-secondary period-btn" bindtap="onSetEndDate">设为结束日</button>
        <button class="btn-danger period-btn" bindtap="onDeletePeriod">删除记录</button>
      </view>
    </block>

    <!-- 预测经期 -->
    <block wx:elif="{{isPredicted}}">
      <view class="period-info">
        <view class="predict-hint">该日期为预测经期</view>
      </view>
      <button class="btn-primary period-confirm-btn" bindtap="onConfirmPredicted">确认为实际经期</button>
    </block>

    <!-- 非经期 -->
    <block wx:else>
      <view class="period-info">
        <view class="no-period-hint">该日期暂无经期记录</view>
      </view>
      <button class="btn-primary period-confirm-btn" bindtap="onMarkPeriodStart">标记为经期开始</button>
    </block>
  </view>

  <!-- 每日记录区 -->
  <view class="card daily-card">
    <view class="card-title">每日记录</view>

    <!-- 经血量 -->
    <view class="section">
      <view class="section-label">经血量</view>
      <view class="flow-options">
        <view class="flow-item {{flow === 'light' ? 'active' : ''}}" bindtap="onFlowSelect" data-flow="light">
          <view class="flow-dot flow-light"></view>
          <text>轻</text>
        </view>
        <view class="flow-item {{flow === 'medium' ? 'active' : ''}}" bindtap="onFlowSelect" data-flow="medium">
          <view class="flow-dot flow-medium"></view>
          <text>中</text>
        </view>
        <view class="flow-item {{flow === 'heavy' ? 'active' : ''}}" bindtap="onFlowSelect" data-flow="heavy">
          <view class="flow-dot flow-heavy"></view>
          <text>重</text>
        </view>
      </view>
    </view>

    <!-- 症状选择 -->
    <view class="section">
      <view class="section-label">症状</view>
      <view class="symptom-tags">
        <view
          wx:for="{{symptomList}}" wx:key="key"
          class="symptom-tag {{item.selected ? 'active' : ''}}"
          bindtap="onSymptomToggle" data-key="{{item.key}}"
        >{{item.label}}</view>
      </view>
    </view>

    <!-- 心情选择 -->
    <view class="section">
      <view class="section-label">心情</view>
      <view class="mood-options">
        <view
          wx:for="{{moodList}}" wx:key="key"
          class="mood-item {{mood === item.key ? 'active' : ''}}"
          bindtap="onMoodSelect" data-mood="{{item.key}}"
        >
          <text class="mood-emoji">{{item.emoji}}</text>
          <text class="mood-label">{{item.label}}</text>
        </view>
      </view>
    </view>

    <!-- 体温记录 -->
    <view class="section">
      <view class="section-label">体温 (°C)</view>
      <input
        class="temp-input"
        type="digit"
        placeholder="选填，如 36.5"
        value="{{temperature}}"
        bindinput="onTemperatureInput"
      />
    </view>

    <!-- 备注 -->
    <view class="section">
      <view class="section-label">备注</view>
      <textarea
        class="notes-input"
        placeholder="记录今天的感受..."
        value="{{notes}}"
        bindinput="onNotesInput"
        maxlength="200"
        auto-height
      />
    </view>
  </view>

  <!-- 症状相关健康文章 -->
  <view class="card symptom-articles-card" wx:if="{{symptomArticles.length || phaseArticles.length}}">
    <view class="card-title article-card-title">
      <text>💡 {{recommendTitle}}</text>
      <text class="article-card-more" bindtap="onGoHealth">更多 ›</text>
    </view>
    <view class="symptom-article-list">
      <view
        class="symptom-article-item"
        wx:for="{{symptomArticles}}"
        wx:key="id"
        bindtap="onArticleTap"
        data-id="{{item.id}}"
      >
        <view class="sa-tag sa-tag--symptom">{{item.matchSymptom}}</view>
        <view class="sa-content">
          <view class="sa-title">{{item.title}}</view>
          <view class="sa-meta">⏱ {{item.readTime}}分钟阅读</view>
        </view>
        <view class="sa-arrow">›</view>
      </view>
      <view
        class="symptom-article-item"
        wx:for="{{phaseArticles}}"
        wx:for-item="pItem"
        wx:key="id"
        bindtap="onArticleTap"
        data-id="{{pItem.id}}"
      >
        <view class="sa-tag sa-tag--phase">{{pItem.matchPhase}}</view>
        <view class="sa-content">
          <view class="sa-title">{{pItem.title}}</view>
          <view class="sa-meta">⏱ {{pItem.readTime}}分钟阅读</view>
        </view>
        <view class="sa-arrow">›</view>
      </view>
    </view>
  </view>

  <!-- 保存按钮 -->
  <view class="save-area">
    <button class="btn-primary save-btn" bindtap="onSave">保存记录</button>
  </view>

  <!-- 保存成功后的健康洞察弹窗 -->
  <view class="insight-modal" wx:if="{{showInsight && recordInsight}}" catchtap="noop">
    <view class="insight-modal-wrap">
      <view class="imw-header">
        <text class="imw-icon">✨</text>
        <text class="imw-title">健康洞察</text>
        <view class="imw-close" bindtap="onCloseInsight">✕</view>
      </view>

      <view class="imw-body">
        <view class="imw-phase-tag">
          <text>{{recordInsight.phaseLabel || '今日'}}记录分析</text>
        </view>

        <!-- 洞察 -->
        <view class="imw-section" wx:if="{{recordInsight.insights.length}}">
          <view class="imw-section-title">💡 你知道吗</view>
          <view class="imw-insight-item" wx:for="{{recordInsight.insights}}" wx:key="*this">
            <view class="insight-dot-purple"></view>
            <text class="imw-insight-text">{{item}}</text>
          </view>
        </view>

        <!-- 改善建议 -->
        <view class="imw-section" wx:if="{{recordInsight.tips.length}}">
          <view class="imw-section-title">🌿 改善建议</view>
          <view class="imw-tip-item" wx:for="{{recordInsight.tips}}" wx:key="*this">
            <text class="imw-tip-num">{{index + 1}}</text>
            <text class="imw-tip-text">{{item}}</text>
          </view>
        </view>

        <!-- 空状态提示 -->
        <view class="imw-empty" wx:if="{{!recordInsight.insights.length && !recordInsight.tips.length}}">
          <text class="imw-empty-icon">📝</text>
          <text class="imw-empty-text">记录越完整，健康洞察越丰富\n下次试着记录更多身体感受吧</text>
        </view>
      </view>

      <view class="imw-actions">
        <button class="imw-btn imw-btn--secondary" bindtap="onInsightGoRecord">
          查看健康档案
        </button>
        <button class="imw-btn imw-btn--primary" bindtap="onCloseInsight">
          完成
        </button>
      </view>
    </view>
  </view>

</view>
