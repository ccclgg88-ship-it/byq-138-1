/* pages/record/record.wxss */

.record-page {
  padding-bottom: 60rpx;
}

/* ===== 日期信息头 ===== */
.date-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 32rpx 32rpx;
}

.date-text {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 16rpx;
}

.phase-tag {
  display: inline-block;
  padding: 8rpx 28rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.phase-menstrual,
.phase-predicted_menstrual {
  background: var(--color-primary-pale);
  color: var(--color-primary);
}

.phase-ovulation {
  background: var(--color-fertile);
  color: var(--color-ovulation);
}

.phase-follicular,
.phase-luteal {
  background: #E8F4FD;
  color: #5B9BD5;
}

.phase-safe,
.phase-unknown {
  background: var(--color-safe-bg);
  color: var(--color-safe);
}

/* ===== 经期操作区 ===== */
.period-card {
  margin-top: 8rpx;
}

.period-info {
  margin-bottom: 24rpx;
}

.period-day-badge {
  display: inline-block;
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  padding: 12rpx 32rpx;
  border-radius: 28rpx;
}

.period-actions {
  display: flex;
  gap: 20rpx;
}

.period-btn {
  flex: 1;
  font-size: 26rpx;
  padding: 16rpx 0;
  border-radius: var(--radius-xl);
}

.btn-danger {
  background: #FFF0F0;
  color: #E74C3C;
  border: none;
  border-radius: var(--radius-xl);
  font-size: 26rpx;
  padding: 16rpx 0;
}

.btn-danger::after {
  border: none;
}

.predict-hint {
  font-size: 28rpx;
  color: var(--color-ovulation);
  font-weight: 500;
}

.no-period-hint {
  font-size: 28rpx;
  color: var(--color-text-light);
}

.period-confirm-btn {
  margin-top: 8rpx;
  width: 100%;
  font-size: 28rpx;
}

/* ===== 每日记录区 ===== */
.section {
  margin-bottom: 36rpx;
}

.section:last-child {
  margin-bottom: 0;
}

.section-label {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 16rpx;
}

/* 经血量 */
.flow-options {
  display: flex;
  justify-content: center;
  gap: 48rpx;
}

.flow-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  padding: 16rpx 24rpx;
  border-radius: var(--radius-md);
  transition: all 0.2s;
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.flow-item.active {
  background: var(--color-primary-pale);
  color: var(--color-primary);
}

.flow-dot {
  border-radius: 50%;
  background: var(--color-border);
  transition: background 0.2s;
}

.flow-light { width: 32rpx; height: 32rpx; }
.flow-medium { width: 44rpx; height: 44rpx; }
.flow-heavy { width: 56rpx; height: 56rpx; }

.flow-item.active .flow-dot {
  background: var(--color-primary);
}

/* 症状标签 */
.symptom-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.symptom-tag {
  padding: 12rpx 28rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  background: #F5F5F5;
  color: var(--color-text-secondary);
  transition: all 0.2s;
}

.symptom-tag.active {
  background: var(--color-primary-pale);
  color: var(--color-primary);
  font-weight: 500;
}

/* 心情选择 */
.mood-options {
  display: flex;
  justify-content: space-between;
}

.mood-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 12rpx;
  border-radius: var(--radius-md);
  transition: all 0.2s;
  min-width: 100rpx;
}

.mood-item.active {
  background: var(--color-primary-pale);
}

.mood-emoji {
  font-size: 48rpx;
}

.mood-label {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.mood-item.active .mood-label {
  color: var(--color-primary);
  font-weight: 500;
}

/* 体温输入 */
.temp-input {
  background: #F8F8F8;
  border-radius: var(--radius-md);
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: var(--color-text);
}

/* 备注输入 */
.notes-input {
  background: #F8F8F8;
  border-radius: var(--radius-md);
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: var(--color-text);
  width: 100%;
  min-height: 120rpx;
  box-sizing: border-box;
}

/* ===== 保存按钮 ===== */
.save-area {
  padding: 24rpx 24rpx 48rpx;
}

.save-btn {
  /* width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx; */
}

/* ===== 症状相关文章卡片 ===== */
.symptom-articles-card {
  margin-top: 8rpx;
  background: linear-gradient(135deg, #FFFBFC 0%, #F8F4FF 100%);
}

.article-card-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #FF6B8A;
  margin-bottom: 20rpx;
}

.article-card-more {
  font-size: 24rpx;
  color: #FF6B8A;
  font-weight: normal;
}

.symptom-article-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.symptom-article-item {
  display: flex;
  align-items: center;
  padding: 20rpx 16rpx;
  border-radius: 16rpx;
  transition: all 0.2s;
  gap: 16rpx;
}

.symptom-article-item:active {
  background: rgba(255, 107, 138, 0.06);
}

.sa-tag {
  flex-shrink: 0;
  font-size: 20rpx;
  padding: 6rpx 14rpx;
  border-radius: 12rpx;
  font-weight: 500;
}

.sa-tag--symptom {
  background: #FFE4EA;
  color: #FF6B8A;
}

.sa-tag--phase {
  background: #E8DEFF;
  color: #9B6BFF;
}

.sa-content {
  flex: 1;
  min-width: 0;
}

.sa-title {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
  line-height: 1.4;
  margin-bottom: 6rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.sa-meta {
  font-size: 20rpx;
  color: #999;
}

.sa-arrow {
  flex-shrink: 0;
  font-size: 32rpx;
  color: #CCC;
}

/* ===== 保存后健康洞察弹窗 ===== */
.insight-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.55);
  z-index: 2000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.insight-modal-wrap {
  width: 100%;
  background: #FFF;
  border-radius: 32rpx;
  overflow: hidden;
  animation: slideUp 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

@keyframes slideUp {
  from {
    transform: translateY(80rpx);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

.imw-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 28rpx 28rpx 20rpx;
  background: linear-gradient(135deg, #FFF0F5 0%, #F8F4FF 100%);
  position: relative;
}

.imw-icon {
  font-size: 36rpx;
}

.imw-title {
  flex: 1;
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
}

.imw-close {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: rgba(155, 107, 255, 0.1);
  color: #999;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
}

.imw-body {
  padding: 24rpx 28rpx 8rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.imw-phase-tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  background: #F8F4FF;
  color: #9B6BFF;
  font-size: 24rpx;
  font-weight: 500;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
}

.imw-section {
  margin-bottom: 24rpx;
}

.imw-section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #9B6BFF;
  margin-bottom: 14rpx;
}

.imw-insight-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  padding: 16rpx;
  background: #FBF9FF;
  border-radius: 14rpx;
  margin-bottom: 10rpx;
  border-left: 4rpx solid #9B6BFF;
}

.imw-insight-item:last-child {
  margin-bottom: 0;
}

.insight-dot-purple {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #9B6BFF;
  margin-top: 10rpx;
  flex-shrink: 0;
}

.imw-insight-text {
  flex: 1;
  font-size: 26rpx;
  color: #333;
  line-height: 1.7;
}

.imw-tip-item {
  display: flex;
  gap: 12rpx;
  padding: 12rpx 0;
  border-bottom: 1rpx dashed #F0F0F0;
}

.imw-tip-item:last-child {
  border-bottom: none;
}

.imw-tip-num {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF6B8A, #FF9EAE);
  color: #FFF;
  font-size: 22rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.imw-tip-text {
  flex: 1;
  font-size: 26rpx;
  color: #555;
  line-height: 1.6;
}

.imw-empty {
  text-align: center;
  padding: 32rpx 20rpx;
}

.imw-empty-icon {
  font-size: 56rpx;
  display: block;
  margin-bottom: 16rpx;
}

.imw-empty-text {
  font-size: 24rpx;
  color: #999;
  line-height: 1.6;
  white-space: pre-line;
}

.imw-actions {
  display: flex;
  gap: 16rpx;
  padding: 20rpx 28rpx 28rpx;
}

.imw-btn {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 42rpx;
  text-align: center;
  border: none;
}

.imw-btn::after {
  border: none;
}

.imw-btn--primary {
  background: linear-gradient(135deg, #FF6B8A, #FF8FA3);
  color: #FFF;
  box-shadow: 0 6rpx 20rpx rgba(255, 107, 138, 0.35);
}

.imw-btn--secondary {
  background: #F8F4FF;
  color: #9B6BFF;
}
